{
  "manifest_version": 3,
  "name": "Spotify Unfollowers",
  "version": "1.1.0",
  "description": "Find who doesn't follow you back on Spotify.",
  "permissions": ["activeTab", "storage"],
  "host_permissions": ["https://open.spotify.com/*"],
  "content_security_policy": {
    "extension_pages": "style-src 'unsafe-inline' https://fonts.googleapis.com; font-src https://fonts.gstatic.com data:; img-src https://i.scdn.co https://open.spotify.com data:; default-src 'self';"
  },
  "action": {
    "default_popup": "popup.html",
    "default_icon": {
      "16": "icons/icon16.png",
      "32": "icons/icon32.png",
      "48": "icons/icon48.png",
      "64": "icons/icon64.png",
      "128": "icons/icon128.png"
    }
  },
  "content_scripts": [
    {
      "matches": ["https://open.spotify.com/user/*"],
      "js": ["content/interceptor.js"],
      "run_at": "document_start",
      "world": "MAIN"
    },
    {
      "matches": ["https://open.spotify.com/*"],
      "js": ["content.js"],
      "css": ["content/content.css"]
    }
  ],
  "background": {
    "service_worker": "background.js"
  },
  "commands": {
    "start-scan": {
      "suggested_key": { "default": "Ctrl+Shift+U", "mac": "Command+Shift+U" },
      "description": "Start Spotify Unfollowers scan"
    }
  },
  "icons": {
    "16": "icons/icon16.png",
    "32": "icons/icon32.png",
    "48": "icons/icon48.png",
    "64": "icons/icon64.png",
    "128": "icons/icon128.png"
  }
}
